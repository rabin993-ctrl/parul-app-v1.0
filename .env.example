# ── Required ─────────────────────────────────────────────────────────────────
# Supabase project URL and anonymous key (Settings → API in Supabase Dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── Optional ──────────────────────────────────────────────────────────────────
# Cloudflare CDN in front of Supabase Storage (e.g. https://cdn.parul.pet)
EXPO_PUBLIC_CDN_URL=

# NOTE: thumbnail generation runs server-side via the VPS cron. Do NOT add a
# EXPO_PUBLIC_THUMB_WEBHOOK_SECRET here — EXPO_PUBLIC_* vars are inlined into the
# client bundle, so any secret shipped this way is exposed on every device.

# Sentry error reporting DSN
EXPO_PUBLIC_SENTRY_DSN=

# Feature flags (set to "false" to disable)
EXPO_PUBLIC_BETA_FEEDBACK_ENABLED=true
EXPO_PUBLIC_APP_TUTORIAL_ENABLED=true
